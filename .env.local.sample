# ── Aadhaar Hashing Salt (any string — used for keccak256 hash) ──
AADHAAR_HASH_SALT=blockchain-agentic-vote-local-dev-salt

# ── NextAuth.js ──
NEXTAUTH_SECRET=super-secret-nextauth-key-for-local-dev-only
NEXTAUTH_URL=http://localhost:3000

# ── Blockchain (Local Hardhat) ──
# Hardhat account #0 private key (well-known, only for local dev)
RELAYER_PRIVATE_KEY=private-key-of-hardhat-account-0
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337


OPENROUTER_API_KEY=your-open-router-api-key
# Model to use (any OpenRouter model slug). Default: google/gemini-2.0-flash-001
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Vote Batching ──
BATCH_THRESHOLD=5
MAX_WAIT_SECONDS=60
